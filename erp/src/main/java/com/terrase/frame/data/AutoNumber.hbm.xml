<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
	<class name="com.terrase.frame.data.AutoNumber" schema="dbo"
		table="auto_numbers" where="deleted != 1">
		<id name="id" type="java.lang.Long">
			<column name="id" />
			<generator class="identity" />
		</id>
		<version name="version" type="int">
			<column name="version" />
		</version>

		<property name="code" type="string"
			unique-key="unique_auto_number">
			<column name="code" length="100" />
		</property>
		<property name="name" type="string">
			<column name="name" length="500" />
		</property>
		<property name="description" type="string">
			<column name="description" length="500" />
		</property>

		<property name="prefix" type="string">
			<column name="prefix" length="100" />
		</property>
		<property name="postfix" type="string">
			<column name="postfix" length="100" />
		</property>
		<property name="length" type="int">
			<column name="length" />
		</property>

		<property name="sequence" type="int">
			<column name="sequence" />
		</property>
		<property name="year" type="int">
			<column name="year" />
		</property>
		<property name="month" type="int">
			<column name="month" />
		</property>
		<property name="day" type="int">
			<column name="day" />
		</property>

		<property name="resetBy" column="reset_by">
			<type name="org.hibernate.type.EnumType">
				<param name="enumClass">com.terrase.frame.enumerator.EnumAutoNumberReset</param>
			</type>
		</property>

		<property name="systemSequence" type="boolean">
			<column name="system_sequence" />
		</property>

		<property name="dateCreated" type="timestamp" insert="false">
			<column name="date_created" default="current_timestamp" />
		</property>
		<many-to-one name="userCreated"
			class="com.terrase.frame.data.User" lazy="false" fetch="select"
			not-found="ignore">
			<column name="user_created" not-null="true" />
		</many-to-one>

		<property name="dateModified" type="timestamp">
			<column name="date_modified" />
		</property>
		<many-to-one name="userModified"
			class="com.terrase.frame.data.User" lazy="false" fetch="select"
			not-found="ignore">
			<column name="user_modified" not-null="false" />
		</many-to-one>

		<property name="deleted" type="boolean"
			unique-key="unique_auto_number">
			<column name="deleted" />
		</property>
		<property name="dateDeleted" type="timestamp"
			unique-key="unique_auto_number">
			<column name="date_deleted" />
		</property>
		<many-to-one name="userDeleted"
			class="com.terrase.frame.data.User" lazy="false" fetch="select"
			not-found="ignore">
			<column name="user_deleted" not-null="false" />
		</many-to-one>
	</class>
</hibernate-mapping>
