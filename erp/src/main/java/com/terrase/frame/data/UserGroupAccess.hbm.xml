<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
	<class name="com.terrase.frame.data.UserGroupAccess"
		table="user_group_accesses" where="deleted != 1">
		<id name="id" type="java.lang.Long">
			<column name="id" />
			<generator class="identity" />
		</id>
		<version name="version" type="int">
			<column name="version" />
		</version>

		<many-to-one name="userGroup"
			class="com.terrase.frame.data.UserGroup" lazy="false" fetch="select"
			not-found="ignore">
			<column name="user_group_id" not-null="false" />
		</many-to-one>
		<many-to-one name="module"
			class="com.terrase.frame.data.Module" lazy="false" fetch="select"
			not-found="ignore">
			<column name="module_id" not-null="true" />
		</many-to-one>

		<property name="viewRights" type="boolean">
			<column name="view_rights" />
		</property>
		<property name="addRights" type="boolean">
			<column name="add_rights" />
		</property>
		<property name="updateRights" type="boolean">
			<column name="update_rights" />
		</property>
		<property name="deleteRights" type="boolean">
			<column name="delete_rights" />
		</property>
		<property name="printRights" type="boolean">
			<column name="print_rights" />
		</property>
		<property name="postRights" type="boolean">
			<column name="post_rights" />
		</property>

		<property name="dateCreated" type="timestamp" insert="false">
			<column name="date_created" default="current_timestamp" />
		</property>
		<many-to-one name="userCreated"
			class="com.terrase.frame.data.User" lazy="false" fetch="select"
			not-found="ignore">
			<column name="user_created" not-null="true" />
		</many-to-one>

		<property name="dateModified" type="timestamp">
			<column name="date_modified" />
		</property>
		<many-to-one name="userModified"
			class="com.terrase.frame.data.User" lazy="false" fetch="select"
			not-found="ignore">
			<column name="user_modified" not-null="false" />
		</many-to-one>

		<property name="deleted" type="boolean">
			<column name="deleted" />
		</property>
		<property name="dateDeleted" type="timestamp">
			<column name="date_deleted" />
		</property>
		<many-to-one name="userDeleted"
			class="com.terrase.frame.data.User" lazy="false" fetch="select"
			not-found="ignore">
			<column name="user_deleted" not-null="false" />
		</many-to-one>
	</class>
</hibernate-mapping>
